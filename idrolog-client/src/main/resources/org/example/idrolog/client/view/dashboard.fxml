<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768.0" prefWidth="1024.0" stylesheets="@../../../../../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.idrolog.client.ui.controller.DashboardController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" />
            </padding>
            <Label styleClass="title-main" text="IdroLog" />
        </HBox>
    </top>

    <center>
        <VBox spacing="20.0" BorderPane.alignment="CENTER">

            <HBox spacing="20.0" VBox.vgrow="NEVER">

                <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="2.0">
                    <Label styleClass="text-muted" text="Livello Attuale" />
                    <HBox alignment="BASELINE_LEFT" spacing="8.0">
                        <Label fx:id="currentLevelLabel" styleClass="kpi-value" text="-- m" />
                        <Label fx:id="lastUpdateLabel" styleClass="text-muted" text="(--:--)" />
                    </HBox>
                    <HBox spacing="15.0">
                        <Label fx:id="statusLabel" styleClass="text-bold" text="Stato: Normale" />
                        <Label fx:id="trendLabel" styleClass="text-muted" text="Tendenza: --" />
                    </HBox>
                </VBox>

                <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="2.0">
                    <Label fx:id="precipitationTitleLabel" styleClass="text-muted" text="Precipitazioni 24h" />
                    <Label fx:id="precipitationLabel" styleClass="kpi-value" text="0.0 mm" />
                    <Label fx:id="precipitationStatusLabel" styleClass="text-muted" text="Sensore non collegato" />
                </VBox>

                <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="5.0">
                    <Label styleClass="title-section" text="Avvisi" />
                    <VBox spacing="2.0" styleClass="alert-box" VBox.vgrow="ALWAYS" alignment="CENTER_LEFT">
                        <Label styleClass="text-white-bold" text="Nessuna Allerta" />
                        <Label styleClass="text-white" text="Condizioni stabili." wrapText="true" minHeight="-Infinity" />
                    </VBox>
                </VBox>

            </HBox>

            <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10.0">
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label styleClass="title-section" text="Andamento Livello Idrometrico" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="text-muted" text="Visualizza:" />
                    <ComboBox fx:id="hoursComboBox" prefWidth="120.0" styleClass="combo-box-modern" />
                </HBox>
                <LineChart fx:id="riverLevelChart" legendVisible="false" VBox.vgrow="ALWAYS">
                    <xAxis>
                        <CategoryAxis fx:id="timeAxis" label="Orario" side="BOTTOM" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis fx:id="levelAxis" label="Metri (m)" side="LEFT" />
                    </yAxis>
                </LineChart>
            </VBox>

        </VBox>
    </center>
</BorderPane>